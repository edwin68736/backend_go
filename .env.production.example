# Copiar en el VPS como /opt/tukifac/.env
# MySQL en otro VPS — NO incluir MySQL en docker-compose.

# ── Imagen Docker (CI / GHCR) — usar tag sha en producción ──────────
# Ejemplo: ghcr.io/mi-org/backend_principal:a1b2c3d4...
TUKIFAC_IMAGE=ghcr.io/TU_ORG/backend_principal:latest

# ── Base de datos (VPS MySQL remoto) ──────────────────────────────
DB_HOST=10.0.0.5
DB_PORT=3306
DB_USER=tukifac_app
DB_PASSWORD=cambiar_por_secreto_fuerte
CENTRAL_DB_NAME=tukifac_saas

# El usuario MySQL necesita: SELECT, INSERT, UPDATE, DELETE, CREATE, ALTER, INDEX, DROP
# (EnsureCentralDB y CreateTenantDB ejecutan CREATE DATABASE en arranque/alta de tenant)

# ── Dominio y entorno ─────────────────────────────────────────────
APP_ENV=production
# Dominio RAÍZ (tenants: empresa1.APP_DOMAIN). NO usar api.* ni app.* aquí.
APP_DOMAIN=tukifac.com
# ROOT_DOMAIN=tukifac.com
PORT=3000
TZ=America/Lima

# ── JWT (generar con: openssl rand -hex 32) ───────────────────────
JWT_SECRET=
SA_JWT_SECRET=

# ── Pool MySQL (ajustar según max_connections del VPS DB) ───────────
DB_CENTRAL_MAX_OPEN=40
DB_CENTRAL_MAX_IDLE=15
DB_TENANT_MAX_OPEN=3
DB_TENANT_MAX_IDLE=2
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

# ── Redis (VPS2 — contenedor tukifac-redis en red Docker del backend) ─
# Usar hostname del contenedor, NO 127.0.0.1 (eso es el propio backend).
REDIS_URL=redis://tukifac-redis:6379/0
# Alternativa equivalente:
# REDIS_ADDR=tukifac-redis:6379
# REDIS_HOST=tukifac-redis
# REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=50
REDIS_MIN_IDLE_CONNS=10
REDIS_MAX_RETRIES=5

# ── Rendimiento multi-tenant ────────────────────────────────────────
TENANT_METADATA_TTL=5m

# ── Migraciones CLI (deploy: migrate-central antes del restart; fleet = cron) ─
MIGRATION_BATCH_SIZE=50
MIGRATION_BATCH_PAUSE=2s
MIGRATE_TIMEOUT_SEC=3600
# Lock fleet cron: Redis (REDIS_URL) o MySQL GET_LOCK; flock en script como fallback host
# FLEET_LOCK_LEASE_SEC=3600
FLEET_CIRCUIT_BREAKER_THRESHOLD=10
# AUTO_MIGRATE_DEV=true   # solo desarrollo local (go run), NUNCA en producción

# ── HTTP ───────────────────────────────────────────────────────────
BODY_LIMIT_BYTES=12582912
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=120s
HTTP_IDLE_TIMEOUT=120s

# ── Rate limiting (req por minuto; ver docs/PRODUCTION-HARDENING.md) ─
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL=300
RATE_LIMIT_AUTH=10
RATE_LIMIT_BILLING=60
RATE_LIMIT_UPLOAD=30
RATE_LIMIT_PUBLIC_CONSULT=20

# ── Logging estructurado (JSON en producción) ─────────────────────
LOG_LEVEL=info

# ── Almacenamiento en contenedor (coincidir con volúmenes compose) ─
INVOICE_STORAGE_PATH=/app/storage/invoices

# Facturador (VPS dedicado) — requerido para emisión fiscal
FACTURADOR_BASE_URL=http://localhost:8000
FACTURADOR_TOKEN=123456
FISCAL_QUEUE_WORKERS=4
INTERNAL_API_KEY=clave-compartida-con-facturador
# VALIDAPSE_MGMT_BASE_URL=https://app.validapse.com/api
# VALIDAPSE_MGMT_TOKEN=

# ── Hosts públicos (no son tenants) ───────────────────────────────
API_PUBLIC_URL=https://api.midominio.com
# API_HOST=api.midominio.com
FRONTEND_URL=https://app.midominio.com
CENTRAL_FRONTEND_URL=https://app.midominio.com
# Subdominios reservados (no crear tenant con estos slugs)
RESERVED_SUBDOMAINS=api,app,www,admin,central
# Orígenes extra (coma). Tauri/Capacitor ya están en código (tauri.localhost, https://localhost).
# Solo si pruebas Vite contra API prod sin proxy:
# CORS_ALLOWED_ORIGINS=http://localhost:5175

# ── Ubigeo (opcional; por defecto datos embebidos en el binario) ───
# UBIGEO_DISTRITOS_CSV=/app/data/ubigeo.csv
