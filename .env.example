# =============================================================================
# Tukifac — Backend Go (copiar a .env)
# Desarrollo local abajo. Bloque producción al final (tukifac.com).
# =============================================================================

# ── Base de datos ──────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
CENTRAL_DB_NAME=tukifac_saas

# ── Dominios ───────────────────────────────────────────────────────
# Dominio RAÍZ: tenants = https://{slug}.APP_DOMAIN  (ej. demo.tukifac.com)
APP_DOMAIN=localhost

# Panel central React (superadmin) — NO es un tenant
CENTRAL_FRONTEND_URL=http://localhost:5174

# Frontend tenant React (SPA por empresa) — en prod suele ser el mismo host que cada tenant
FRONTEND_URL=http://localhost:5173

# API pública central — superadmin, login bootstrap, tenant-by-ruc
API_PUBLIC_URL=http://localhost:3000

# Subdominios que NUNCA son slug de tenant (se fusionan con la lista por defecto)
# RESERVED_SUBDOMAINS=api,app,www,admin,central

# ── JWT (cambiar en producción) ────────────────────────────────────
JWT_SECRET=tenant-secret-change-in-production
SA_JWT_SECRET=superadmin-secret-change-in-production

# ── Entorno ────────────────────────────────────────────────────────
APP_ENV=development

# ── Servidor ───────────────────────────────────────────────────────
PORT=3000
# AUTO_MIGRATE_DEV=true

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── Pool MySQL ─────────────────────────────────────────────────────
DB_CENTRAL_MAX_OPEN=25
DB_TENANT_MAX_OPEN=2

# ── Facturación async ──────────────────────────────────────────────
BILLING_ASYNC_ENABLED=true
FACTURADOR_BASE_URL=http://localhost:8000
FACTURADOR_TOKEN=
FISCAL_QUEUE_WORKERS=4
INTERNAL_API_KEY=
INVOICE_STORAGE_PATH=./storage/invoices

# ── Correo (comprobantes restaurante / alertas) ────────────────────
# Dejar SMTP_HOST vacío para desactivar el envío por correo.
#
# ── Gmail (recomendado para pruebas) ───────────────────────────────
# Valores por defecto del servidor SMTP de Google:
#   Host: smtp.gmail.com
#   Puerto: 587 (STARTTLS) — el backend usa smtp.PlainAuth en este puerto
#
# Pasos:
#   1. Cuenta Google con verificación en 2 pasos activada
#   2. Crear contraseña de aplicación: https://myaccount.google.com/apppasswords
#      (Google Account → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones)
#   3. Usar esa contraseña de 16 caracteres en SMTP_PASSWORD (NO la contraseña normal)
#   4. SMTP_USER y SMTP_FROM deben ser el mismo correo @gmail.com (o @googlemail.com)
#
# Ejemplo listo para copiar a tu .env (reemplaza usuario y contraseña de app):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu.cuenta@gmail.com
# SMTP_PASSWORD=abcd efgh ijkl mnop
# SMTP_FROM=tu.cuenta@gmail.com
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu.cuenta@gmail.com
SMTP_PASSWORD=
SMTP_FROM=tu.cuenta@gmail.com

# CORS extra (opcional, separados por coma)
# CORS_ALLOWED_ORIGINS=

# =============================================================================
# PRODUCCIÓN — VPS tukifac.com (copiar estos valores al .env del servidor)
# =============================================================================
#
# APP_ENV=production
# APP_DOMAIN=tukifac.com
#
# API_PUBLIC_URL=https://api.tukifac.com
# CENTRAL_FRONTEND_URL=https://app.tukifac.com
# FRONTEND_URL=https://app.tukifac.com
#
# RESERVED_SUBDOMAINS=api,app,www,admin,central
#
# JWT_SECRET=<openssl rand -hex 32>
# SA_JWT_SECRET=<openssl rand -hex 32>
#
# DB_HOST=<ip-vps-mysql>
# DB_PORT=3306
# DB_USER=tukifac_app
# DB_PASSWORD=<secreto>
# CENTRAL_DB_NAME=tukifac_saas
#
# REDIS_URL=redis://tukifac-redis:6379/0
# INVOICE_STORAGE_PATH=/app/storage/invoices
# FACTURADOR_BASE_URL=https://facturador.tukifac.com
# FACTURADOR_TOKEN=<token-facturador>
# INTERNAL_API_KEY=<clave-webhook-fiscal>
#
# Arquitectura de dominios:
#   Panel central:     https://app.tukifac.com
#   API central:       https://api.tukifac.com
#   Tenant demo:       https://demo.tukifac.com
#   Tenant empresa1:   https://empresa1.tukifac.com
#
# Nginx: *.tukifac.com debe hacer proxy de /api/* al Go con Host={slug}.tukifac.com
# (ver docs/TENANT-ISOLATION.md y docs/DEPLOY-VPS-UBUNTU.md)
#
# Plantilla completa VPS: .env.production.example
