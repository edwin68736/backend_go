# ── Base de datos ──────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
CENTRAL_DB_NAME=tukifac_saas

# ── Dominios (todo configurable, sin hardcode en código) ─────────────
# Dominio raíz: tenants = {slug}.APP_DOMAIN  (ej. empresa1.tukifac.com)
APP_DOMAIN=localhost
# Alias opcional del raíz (si se define, tiene prioridad sobre APP_DOMAIN):
# ROOT_DOMAIN=tukifac.com

# Panel central React (no es tenant)
CENTRAL_FRONTEND_URL=http://localhost:5174
# Frontend tenant React
FRONTEND_URL=http://localhost:5173

# API pública (no es tenant). Usar URL completa o solo host:
API_PUBLIC_URL=http://localhost:3000
# API_HOST=api.tukifac.com

# Subdominios que NUNCA son tenant (se fusionan con api,app,www,admin,central)
# RESERVED_SUBDOMAINS=api,app,www,admin,central

# ── JWT — cambiar por valores seguros en producción ────────────────
JWT_SECRET=tenant-secret-change-in-production
SA_JWT_SECRET=superadmin-secret-change-in-production

# ── Entorno: development | production ─────────────────────────────
APP_ENV=development

# ── Servidor ────────────────────────────────────────────────────────
PORT=3000
# BODY_LIMIT_BYTES=12582912
# HTTP_READ_TIMEOUT=30s
# HTTP_WRITE_TIMEOUT=120s
# AUTO_MIGRATE_DEV=true       # recomendado en dev local: crea tablas centrales + seed al arrancar
# Si el login central falla con "super_admin_users doesn't exist", ejecutar: go run . migrate-central
# MIGRATION_BATCH_SIZE=50
# MIGRATION_BATCH_PAUSE=2s

# Clave de operaciones (panel central → Ajustes SaaS / Cobros): obligatoria para eliminar
# un tenant por completo (BD + archivos). No se guarda en .env; se define en la UI.

# ── Redis (cache tenant + cola facturación async) ───────────────────
# Local:
REDIS_URL=redis://127.0.0.1:6379/0
# Docker (misma red que el backend):
# REDIS_URL=redis://tukifac-redis:6379/0
# REDIS_ADDR=tukifac-redis:6379
# REDIS_HOST=tukifac-redis
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# REDIS_POOL_SIZE=50
# REDIS_MIN_IDLE_CONNS=10
# REDIS_MAX_RETRIES=5
# REDIS_DISABLED=1

# ── Pool MySQL (producción — ver docs/PRODUCTION-HARDENING.md) ─────
# Central: ~25 conexiones. Tenant: 2 open × max 200 pools activos ≈ 400 pico.
DB_CENTRAL_MAX_OPEN=25
DB_TENANT_MAX_OPEN=2
# TENANT_POOL_MAX_ACTIVE=200
# TENANT_POOL_IDLE_TTL=25m
# TENANT_METADATA_TTL=10m
# TENANT_CACHE_NEGATIVE_TTL=60s

# ── Timeouts DB ─────────────────────────────────────────────────────
# DB_READ_TIMEOUT=3s
# DB_WRITE_TIMEOUT=5s
# DB_BILLING_TIMEOUT=45s
# DB_REPORT_TIMEOUT=15s

# ── Facturación async (requiere Redis) ──────────────────────────────
BILLING_ASYNC_ENABLED=true
# BILLING_QUEUE_WORKERS=4
# BILLING_MAX_RETRIES=5

# ── Facturación electrónica ───────────────────────────────────────
# Lycet Facturador SUNAT: URL base (p. ej. http://localhost:8000; se añade /api/v1 si no está) y token (CLIENT_TOKEN)
# El valor de FACTURADOR_TOKEN debe ser EXACTAMENTE el mismo que CLIENT_TOKEN en el .env del servidor Lycet.
FACTURADOR_BASE_URL=http://localhost:8000
FACTURADOR_TOKEN=
# Tukifac (legacy): se usa si FACTURADOR_* no están definidos
TUKIFAC_BASE_URL=
TUKIFAC_API_TOKEN=
# Carpeta donde este backend guarda XML, CDR y PDF de comprobantes (por RUC/serie/numero)
INVOICE_STORAGE_PATH=./storage/invoices

# CORS extra (opcional, separados por coma)
# CORS_ALLOWED_ORIGINS=
# En APP_ENV=development se permiten http://localhost:* y http://*.localhost:* (ej. angel.localhost:5173)

# Producción ejemplo (modelo raíz tukifac.com):
# APP_ENV=production
# APP_DOMAIN=tukifac.com
# API_PUBLIC_URL=https://api.tukifac.com
# FRONTEND_URL=https://app.tukifac.com
# CENTRAL_FRONTEND_URL=https://app.tukifac.com
# Tenants: https://tenant1.tukifac.com  |  API: https://api.tukifac.com  |  Panel: https://app.tukifac.com
#
# Docker en VPS: ver .env.production.example y docs/DEPLOY-VPS-UBUNTU.md
# INVOICE_STORAGE_PATH=/app/storage/invoices (con volúmenes en docker-compose.production.yml)
